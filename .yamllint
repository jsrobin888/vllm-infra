# =============================================================================
# YAML Lint Configuration
# =============================================================================
---
extends: default
rules:
  line-length:
    max: 200
    level: warning
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
  comments:
    require-starting-space: true
    min-spaces-from-content: 1
  indentation:
    spaces: 2
    indent-sequences: true
  document-start: disable

ignore: |
  .git/
  node_modules/
  configs/grafana/dashboards/
