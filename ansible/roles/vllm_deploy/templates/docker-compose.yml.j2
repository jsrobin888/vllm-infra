# =============================================================================
# Docker Compose — vLLM Server Deployment
# Phases 14–18: Container + Engine Configuration
# Generated by Ansible from inventory per-host model definitions
# =============================================================================

services:
{% for model in models_to_serve %}
  vllm-{{ model.name | lower | replace('.', '-') | regex_replace('[^a-z0-9-]', '-') }}:
    image: {{ vllm_image }}:{{ vllm_image_tag }}
    container_name: vllm-{{ model.name | lower | replace('.', '-') | regex_replace('[^a-z0-9-]', '-') }}
    ipc: host
    restart: unless-stopped

    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: [{{ model.gpu_ids.split(',') | map('trim') | map('regex_replace', '^(.*)$', "'\\1'") | join(',') }}]
              capabilities: [gpu]
        limits:
          cpus: '{{ (model.tp_size | int) * 4 }}'
          memory: {{ (model.tp_size | int) * 32 }}G

    ports:
      - "{{ model.port }}:8000"

    volumes:
      - {{ nfs_mount_point }}:/models:ro
      - {{ vllm_log_dir }}:/var/log/vllm:rw

    environment:
      - CUDA_VISIBLE_DEVICES={{ model.gpu_ids }}
      - NCCL_P2P_DISABLE=0
      - NCCL_IB_DISABLE=1
      - VLLM_LOGGING_LEVEL=INFO
{% if vault_hf_token is defined %}
      - HF_TOKEN={{ vault_hf_token }}
{% endif %}

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s

    logging:
      driver: json-file
      options:
        max-size: "{{ docker_log_max_size }}"
        max-file: "{{ docker_log_max_file }}"
        tag: "vllm/{{ model.name }}"

    command: >
      --model /models/{{ model.path | regex_replace('^/mnt/models/', '') }}
      --served-model-name {{ model.name }}
      --host 0.0.0.0
      --port 8000
      --dtype {{ vllm_default_dtype }}
      --tensor-parallel-size {{ model.tp_size }}
      --max-model-len {{ model.max_model_len | default(vllm_default_max_model_len) }}
      --gpu-memory-utilization {{ model.gpu_memory_utilization | default(vllm_default_gpu_memory_utilization) }}
      --max-num-seqs {{ model.max_num_seqs | default(vllm_default_max_num_seqs) }}
{% if vllm_enable_prefix_caching | default(true) %}
      --enable-prefix-caching
{% endif %}
{% if vllm_enable_chunked_prefill | default(true) %}
      --enable-chunked-prefill
{% endif %}
      --disable-log-requests

{% endfor %}
