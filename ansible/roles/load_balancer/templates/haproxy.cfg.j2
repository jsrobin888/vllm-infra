# =============================================================================
# HAProxy Configuration Template (Jinja2)
# Phase 28: Load Balancing — Stages 141-143
# =============================================================================
# Ansible template for HAProxy — generated from inventory.
# =============================================================================

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /var/lib/haproxy/stats/haproxy.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # TLS
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets

    # Performance
    maxconn 10000
    tune.ssl.default-dh-param 2048

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  http-server-close
    option  forwardfor
    timeout connect 10s
    timeout client  300s
    timeout server  300s
    timeout http-request 30s
    timeout http-keep-alive 60s
    timeout queue 60s
    errorfile 429 /etc/haproxy/errors/429.http
    errorfile 503 /etc/haproxy/errors/503.http

# --- Stats ---
listen stats
    bind *:{{ haproxy_stats_port | default(8404) }}
    stats enable
    stats uri /stats
    stats refresh 10s
    stats admin if LOCALHOST
{% if haproxy_stats_auth is defined %}
    stats auth {{ haproxy_stats_auth }}
{% endif %}

# --- Frontend ---
frontend vllm_api
{% if haproxy_tls_cert is defined %}
    bind *:443 ssl crt {{ haproxy_tls_cert }}
    http-request redirect scheme https unless { ssl_fc }
{% else %}
    bind *:{{ haproxy_frontend_port | default(80) }}
{% endif %}

    # Request ID
    unique-id-format %{+X}o\ %ci:%cp_%fi:%fp_%Ts_%rt:%pid
    unique-id-header X-Request-ID

    # Rate limiting
    stick-table type ip size 100k expire 60s store http_req_rate(10s)
    http-request track-sc0 src
    http-request deny deny_status 429 if { sc_http_req_rate(0) gt {{ haproxy_rate_limit | default(100) }} }

{% if haproxy_require_api_key | default(true) %}
    # API key validation
    http-request deny deny_status 401 unless { req.hdr(Authorization) -m found }
    http-request set-var(txn.apikey) req.hdr(Authorization),regsub('^Bearer ','')
    acl valid_key var(txn.apikey) -f /etc/haproxy/maps/api-keys.map
    http-request deny deny_status 403 unless valid_key
{% endif %}

    # Route by model name or use default
{% for model in vllm_models | default([]) %}
    acl is_{{ model.name | replace('-','_') }} path_beg /v1/{{ model.name }}
    use_backend backend_{{ model.name | replace('-','_') }} if is_{{ model.name | replace('-','_') }}
{% endfor %}

    default_backend backend_default

{% for model in vllm_models | default([]) %}
# --- Backend: {{ model.name }} ---
backend backend_{{ model.name | replace('-','_') }}
    balance leastconn
    option httpchk GET /health
    http-check expect status 200
    default-server inter 15s fall 3 rise 2 slowstart 120s

{% for runner in groups['gpu_runners'] %}
{% for m in hostvars[runner].get('models_to_serve', []) %}
{% if m.name == model.name %}
    server {{ runner }}-{{ m.port }} {{ hostvars[runner].ansible_host }}:{{ m.port }} check port {{ m.port }}
{% endif %}
{% endfor %}
{% endfor %}

{% endfor %}

# --- Default backend (first available) ---
backend backend_default
    balance leastconn
    option httpchk GET /health
    http-check expect status 200
    default-server inter 15s fall 3 rise 2

{% for runner in groups['gpu_runners'] %}
{% for m in hostvars[runner].get('models_to_serve', []) %}
    server {{ runner }}-{{ m.port }} {{ hostvars[runner].ansible_host }}:{{ m.port }} check port {{ m.port }}
{% endfor %}
{% endfor %}
